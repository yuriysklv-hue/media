---
// Многоколоночный футер: бренд + дескриптор + соцсети, Разделы, Гео, Медиа.
import { SHOW_SOCIALS } from '../lib/flags';
const cols = [
  {
    title: 'Разделы',
    links: [
      { label: 'Новости', href: '/news' },
      { label: 'Обзоры', href: '/reviews' },
      { label: 'Отчёты', href: '/reports' },
      { label: 'Мнения', href: '/columns' },
      { label: 'Дайджесты', href: '/digest' },
      { label: 'Теги', href: '/tags' },
    ],
  },
  {
    title: 'Гео',
    href: '/geo',
    links: [
      { label: 'Россия', href: '/geo/russia' },
      { label: 'Мир', href: '/geo/world' },
      { label: 'Азия', href: '/geo/asia' },
    ],
  },
  {
    title: 'База знаний',
    href: '/spravochnik',
    links: [
      { label: 'Компании', href: '/spravochnik/#company' },
      { label: 'Технологии', href: '/spravochnik/#technology' },
      { label: 'Термины', href: '/spravochnik/#term' },
      { label: 'Организации', href: '/spravochnik/#organization' },
    ],
  },
  {
    title: 'Медиа',
    links: [
      { label: 'О нас', href: '/about' },
      { label: 'Реклама на сайте', href: '/advertising' },
      { label: 'Редакция', href: '/editorial' },
      { label: 'Контакты', href: '/contacts' },
    ],
  },
];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="logo" href="/" aria-label="1screen.ru">
          <span class="wordmark"><span class="one">1</span>screen<span class="tld">.ru</span></span>
          <span class="tagline">Медиа о рекламе<br />и маркетинге</span>
        </a>
        <p>Профессиональное медиа о рекламе, рекламных технологиях и маркетинге в Мире и России для профессионалов рынка.</p>
        <div class="socials">
          {/* TG/VK скрыты до появления соцканалов — см. src/lib/flags.ts (SHOW_SOCIALS) */}
          {SHOW_SOCIALS && <a href="#" aria-label="Telegram">TG</a>}
          {SHOW_SOCIALS && <a href="#" aria-label="ВКонтакте">VK</a>}
          <a href="/rss.xml" aria-label="RSS">RSS</a>
        </div>
      </div>
      {cols.map((col) => (
        <div class="fcol">
          <h2>{col.href ? <a href={col.href}>{col.title}</a> : col.title}</h2>
          <ul>{col.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <span>© {year} 1screen.ru · Медиа о рекламе и маркетинге</span>
      <span>Сделано в России · Русский</span>
    </div>
  </div>
</footer>
