---
// Элемент ленты (разметка .feed-item с главной): бейдж, заголовок со стрелкой,
// лид, мета. Используется в ленте «Свежее» и на страницах рубрик.
import type { CollectionEntry } from 'astro:content';
import { formatFeedDate, formatReadingTime } from '../lib/format';
import { formatCategory } from '../lib/categories';
import { formatGeo, type ArticleCollection } from '../lib/sections';

interface Props {
  entry: CollectionEntry<ArticleCollection>;
  // Уровень заголовка карточки: 3 в ленте под секцией-h2 (главная),
  // 2 когда лента идёт прямо под h1 страницы (рубрики, гео) — без пропусков.
  headingLevel?: 2 | 3;
}

const { entry, headingLevel = 3 } = Astro.props;
const { data } = entry;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
const now = new Date();
// «Свежая» метка — материалам сегодняшнего дня.
const fresh = data.pubDate.toDateString() === now.toDateString();
const readingTime = formatReadingTime(data.readingTime);
---

<article class="feed-item">
  <span class="badge">{formatCategory(data.category)} {data.geo.map((g) => <span class="geo">{formatGeo(g)}</span>)}</span>
  <Heading><a href={`/article/${entry.id}/`}>{data.title}</a></Heading>
  <p>{data.description}</p>
  <div class="meta-row">
    <span class={fresh ? 'fresh mono' : 'mono'}>{fresh ? '● ' : ''}{formatFeedDate(data.pubDate, now)}</span>
    {readingTime && <><span class="sep">·</span><span class="mono">{readingTime}</span></>}
  </div>
</article>

<style>
  /* ссылка занимает весь заголовок; hover-состояния уже описаны в global.css */
  .feed-item :is(h2, h3) a { color: inherit; }
</style>
