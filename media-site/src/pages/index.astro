---
// Главная страница 1screen.ru. Структура перенесена из канонического макета
// mockups/1screen-mockup-minimal.html; данные — из Content Collections.
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleListItem from '../components/ArticleListItem.astro';
import { ARTICLE_COLLECTIONS, formatGeo, type ArticleCollection } from '../lib/sections';
import { formatCategory } from '../lib/categories';
import { formatDate, formatReadingTime, formatRelative } from '../lib/format';

type Entry = CollectionEntry<ArticleCollection>;
const byDateDesc = (a: Entry, b: Entry) => b.data.pubDate.getTime() - a.data.pubDate.getTime();

const all: Entry[] = (
  await Promise.all(ARTICLE_COLLECTIONS.map((c) => getCollection(c)))
).flat().sort(byDateDesc);

const news = all.filter((e) => e.collection === 'news');
const now = new Date();

// Hero — свежий featured-материал (флагманские отчёты/обзоры); запасной вариант — самый свежий не-новостной.
const hero = all.find((e) => e.data.featured) ?? all.find((e) => e.collection !== 'news') ?? all[0];
const heroAuthor = hero?.data.author ? await getEntry(hero.data.author) : null;

// «Главное сейчас» — 3 свежих новости; live-точка, если новость младше 3 часов.
const sideItems = news.filter((e) => e.id !== hero?.id).slice(0, 3);

// Лента «Свежее» — новости и обзоры, кроме hero и сайд-блока.
const sideIds = new Set(sideItems.map((e) => e.id));
const feed = all
  .filter((e) => (e.collection === 'news' || e.collection === 'reviews') && e.id !== hero?.id && !sideIds.has(e.id))
  .slice(0, 6);

// Сайд-бар: свежий дайджест + «популярное» (пока без статистики — просто свежие заголовки).
const digest = all.find((e) => e.collection === 'digest');
const popular = all.filter((e) => e.id !== hero?.id && e.id !== digest?.id).slice(0, 5);

// «Мнения» — 2 свежие колонки с данными автора.
const columnEntries = all.filter((e) => e.collection === 'columns').slice(0, 2);
const opinions = await Promise.all(
  columnEntries.map(async (entry) => ({
    entry,
    author: entry.data.author ? await getEntry(entry.data.author) : null,
  })),
);

const isLive = (d: Date) => now.getTime() - d.getTime() < 3 * 3_600_000;
---

<BaseLayout>
  <!-- HERO -->
  {hero && (
    <div class="section">
      <div class="wrap">
        <div class="hero-grid">
          <div class="hero-main">
            <span class="badge eyebrow">{formatCategory(hero.data.category)} {hero.data.geo.map((g) => <span class="geo">{formatGeo(g)}</span>)}</span>
            <h1><a href={`/article/${hero.id}/`}>{hero.data.title}</a></h1>
            <p class="lead">{hero.data.description}</p>
            <div class="meta-row">
              {heroAuthor && <><strong>{heroAuthor.data.name}</strong><span class="sep">·</span></>}
              <span class="mono">{formatDate(hero.data.pubDate)}</span>
              {hero.data.readingTime && <><span class="sep">·</span><span class="mono">{formatReadingTime(hero.data.readingTime)}</span></>}
            </div>
          </div>
          <aside class="hero-side">
            <div class="side-head">Главное сейчас</div>
            {sideItems.map((item) => (
              <a class="side-item" href={`/article/${item.id}/`}>
                <span class="badge">{formatCategory(item.data.category)} {item.data.geo.map((g) => <span class="geo">{formatGeo(g)}</span>)}</span>
                <h3>{item.data.title}</h3>
                <span class="m">{isLive(item.data.pubDate) && <span class="dot-live"></span>}{formatRelative(item.data.pubDate, now)}</span>
              </a>
            ))}
          </aside>
        </div>
      </div>
    </div>
  )}

  <!-- ЛЕНТА + САЙД-БАР -->
  <div class="section">
    <div class="wrap">
      <div class="cols">
        <div>
          <div class="sec-head"><h2>Свежее</h2><span class="rule"></span><a class="more" href="/news">Все новости →</a></div>
          <div class="feed">
            {feed.map((entry) => <ArticleListItem entry={entry} />)}
          </div>
        </div>

        <aside class="rail">
          {digest && (
            <div class="rail-mod rail-digest">
              <div class="rail-title">Дайджест недели</div>
              <a class="d-head" href={`/article/${digest.id}/`}>{digest.data.title}</a>
              {digest.data.highlights && (
                <ul class="digest-list">
                  {digest.data.highlights.map((d) => <li>{d}</li>)}
                </ul>
              )}
            </div>
          )}
          <div class="rail-mod">
            <div class="rail-title">Популярное за неделю</div>
            <ol class="pop-list">
              {popular.map((p) => (
                <li class="pop-item"><h4><a href={`/article/${p.id}/`}>{p.data.title}</a></h4></li>
              ))}
            </ol>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- МНЕНИЯ -->
  {opinions.length > 0 && (
    <div class="section subtle">
      <div class="wrap">
        <div class="sec-head"><h2>Мнения</h2><span class="rule"></span><a class="more" href="/columns">Все колонки →</a></div>
        <div class="opinions">
          {opinions.map(({ entry, author }) => (
            <a class="op-card" href={`/article/${entry.id}/`}>
              <span class="badge">{formatCategory(entry.data.category)}</span>
              <blockquote>«{entry.data.title}»</blockquote>
              {author && (
                <div class="op-author">
                  <div class="avatar">{author.data.initials}</div>
                  <div class="who"><div class="n">{author.data.name}</div><div class="r">{author.data.role}</div></div>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- ПОДПИСКА -->
  <div class="section">
    <div class="wrap">
      <div class="newsletter">
        <h2>Раз в неделю — то, что реально сдвинуло рынок</h2>
        <p>Отбираем то, что за неделю действительно повлияло на рынок: РФ, мир, Азия. К каждому пункту — короткий разбор, что он значит для рекламодателя.</p>
        <form class="nl-form" onsubmit="return false">
          <input type="email" placeholder="ваш@email.ru" aria-label="Email" />
          <button type="submit">Подписаться</button>
        </form>
        <div class="nl-note">Никакого спама. Отписка в один клик.</div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* карточки-ссылки наследуют цвета; hover-состояния описаны в global.css */
  .hero-main h1 a, .pop-item h4 a { color: inherit; }
  .side-item, .op-card { display: block; }
  .hero-main h1 a:hover { color: var(--accent-strong); }
</style>
